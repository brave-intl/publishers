{
  "scripts": {
    "start": "NODE_ENV=test karma start",
    "lint": "yarn run lint-scss && yarn run lint-js-css && yarn run lint-ts",
    "lint-scss": "stylelint --config '.stylelintrc-scss.json' 'app/**/*.scss' --syntax scss",
    "lint-js-css": "stylelint --config '.stylelintrc-jsx.json' 'app/**/*.{ts,tsx,js,jsx}'",
    "lint-ts": "tslint --project tsconfig.json 'app/javascript/**/*.{ts,tsx,js,jsx}'",
    "prettier": "prettier --check 'app/javascript/**/*.{ts,tsx,js,jsx}'",
    "test": "jest"
  },
  "husky": {
    "hooks": {
      "pre-commit": "./pre-commit.sh",
      "pre-push": "./pre-push.sh"
    }
  },
  "jest": {
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "jsx",
      "js",
      "json"
    ],
    "globals": {
      "ts-jest": {
        "babelConfig": true,
        "tsConfig": "tsconfig-jest.json",
        "isolatedModules": true
      }
    },
    "resetMocks": true,
    "resetModules": true,
    "collectCoverage": false,
    "collectCoverageFrom": [
      "src/**/*.tsx",
      "!src/**/index.ts"
    ],
    "testMatch": [
      "<rootDir>/app/javascript/**/*.test.jsx"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/app/javascript/testSetup.js"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|svg|ttf|woff|woff2)$": "<rootDir>/.testconfig/fileMocks.ts",
      "\\.(css)$": "identity-obj-proxy"
    },
    "preset": "ts-jest/presets/js-with-babel"
  },
  "dependencies": {
    "@babel/core": ">=7.23.2",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-typescript": "^7.22.5",
    "@babel/runtime": "7.28.6",
    "@github/webauthn-json": "^2.1.1",
    "@rails/activestorage": "^8.0.0",
    "axios": "1.13.6",
    "babel-loader": "10.1.0",
    "brave-ui": "git+https://github.com/brave/brave-ui#4a76f0153255278d5a792bd9e9d1056ef0c602d0",
    "chart.js": "4.5.1",
    "clipboard": "^2.0.11",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dompurify": "^3.3.2",
    "is-accessor-descriptor": "3.0.5",
    "js-yaml": "4.1.1",
    "kind-of": "^6.0.3",
    "mini-css-extract-plugin": "^2.7.6",
    "moment": "^2.29.4",
    "postcss": "^8.5.6",
    "prop-types": "^15.8.1",
    "react": "^16.6.3",
    "react-avatar-editor": "^14.0.0",
    "react-dom": "^16.6.3",
    "react-intl": "^8.0.0",
    "react-select": "^5.7.4",
    "react-tooltip": "^5.21.5",
    "sass": "^1.64.1",
    "sass-loader": "^16.0.0",
    "shakapacker": "9.5.0",
    "stream-browserify": "^3.0.0",
    "style-loader": "^4.0.0",
    "styled-components": "5.3.11",
    "terser-webpack-plugin": "5.3.17",
    "tributejs": "^5.1.3",
    "vm-browserify": "^1.1.2",
    "webpack": "5.105.4",
    "webpack-assets-manifest": "6.5.0",
    "webpack-merge": "6.0",
    "webpack-cli": "6.0.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "7.28.6",
    "@babel/preset-react": "7.28.5",
    "@swc/core": "^1.15.10",
    "@types/jest": "30.0.0",
    "@types/react": "16.14.69",
    "@types/react-dom": "16.9.25",
    "@types/styled-components": "5.1.36",
    "audit-ci": "7.1.0",
    "autoprefixer": "10.4.27",
    "babel-plugin-styled-components": "2.1.4",
    "babel-plugin-syntax-dynamic-import": "6.18.0",
    "babel-plugin-transform-object-rest-spread": "7.0.0-beta.3",
    "cssnano": "7.1.2",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.8",
    "enzyme-to-json": "3.6.2",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "husky": "9.1.7",
    "jest-styled-components": "7.2.0",
    "prettier": "3.8.1",
    "stylelint": "17.4.0",
    "stylelint-config-recommended-scss": "17.0.0",
    "stylelint-config-styled-components": "0.1.1",
    "stylelint-scss": "7.0.0",
    "sugarss": "5.0.1",
    "swc-loader": "^0.2.7",
    "ts-loader": "9.5.4",
    "tslint": "6.1.3",
    "tslint-config-prettier": "1.18.0",
    "tslint-config-standard": "9.0.0",
    "tslint-react": "5.0.0",
    "typescript": "5.9.3"
  },
  "resolutions": {
    "node-fetch": "3.3.2",
    "nth-check": "2.1.1",
    "postcss": "8.5.8",
    "@types/react": "16.14.69",
    "@types/styled-components": "5.1.36"
  },
  "browserslist": [
    "defaults"
  ],
  "packageManager": "yarn@1.22.22"
}
