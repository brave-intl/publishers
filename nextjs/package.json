{
  "name": "creators-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 node ./scripts/create-local-server.js",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && npm run format",
    "lint:strict": "eslint --max-warnings=0 src",
    "postinstall": "patch-package",
    "start": "node ./scripts/create-local-server.js",
    "stylelint": "stylelint \"**/*.css\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@brave/leo": "github:brave/leo#b0d5f184aee1862a37c3bd4dfe854fae5c784daa",
    "@fontsource-variable/mulish": "^5.2.8",
    "@fontsource/dm-mono": "5.2.7",
    "@fontsource/inter": "5.2.8",
    "@fontsource/poppins": "5.2.7",
    "@github/webauthn-json": "^2.1.1",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.95.8",
    "axios": "1.13.5",
    "bs58": "5.0.0",
    "clsx": "^2.0.0",
    "moment": "^2.29.4",
    "next": "^16.1.6",
    "next-intl": "^4.7.0",
    "qr-code-styling": "^1.6.0-rc.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dom-confetti": "^0.2.0",
    "react-responsive": "^9.0.2",
    "react-select": "^5.7.4",
    "web3": "^4.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@faker-js/faker": "8.4.1",
    "@svgr/webpack": "8.1.0",
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "14.3.1",
    "@types/react": "18.3.27",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "autoprefixer": "10.4.24",
    "eslint": "8.57.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-next": "13.5.11",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "express": "5.2.1",
    "http-proxy": "1.18.1",
    "http-proxy-middleware": "3.0.5",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "16.2.7",
    "miragejs": "0.1.48",
    "next-router-mock": "^1.0.5",
    "patch-package": "8.0.1",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "selfsigned": "2.4.1",
    "stylelint": "15.11.0",
    "stylelint-config-clean-order": "5.4.2",
    "stylelint-config-standard": "34.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-webpack-plugin": "4.1.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
