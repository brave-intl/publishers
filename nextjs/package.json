{
  "name": "creators-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 node ./scripts/create-local-server.js",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && npm run format",
    "lint:strict": "eslint --max-warnings=0 src",
    "postinstall": "patch-package",
    "start": "node ./scripts/create-local-server.js",
    "stylelint": "stylelint \"**/*.css\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@brave/leo": "github:brave/leo#391396005212ebb4df7eb19c10a2a6879acfaecf",
    "@fontsource-variable/mulish": "^5.2.8",
    "@fontsource/dm-mono": "5.2.7",
    "@fontsource/inter": "5.2.8",
    "@fontsource/poppins": "5.2.7",
    "@github/webauthn-json": "^2.1.1",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.95.8",
    "axios": "1.13.6",
    "bs58": "6.0.0",
    "clsx": "^2.0.0",
    "moment": "^2.29.4",
    "next": "^16.1.6",
    "next-intl": "^4.7.0",
    "qr-code-styling": "^1.6.0-rc.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dom-confetti": "^0.2.0",
    "react-responsive": "^10.0.0",
    "react-select": "^5.7.4",
    "web3": "^4.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@faker-js/faker": "10.3.0",
    "@svgr/webpack": "8.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.28",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "autoprefixer": "10.4.27",
    "eslint": "10.0.2",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "express": "5.2.1",
    "http-proxy": "1.18.1",
    "http-proxy-middleware": "3.0.5",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "lint-staged": "16.3.2",
    "miragejs": "0.1.48",
    "next-router-mock": "^1.0.5",
    "patch-package": "8.0.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "selfsigned": "5.5.0",
    "stylelint": "17.4.0",
    "stylelint-config-clean-order": "8.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-webpack-plugin": "5.1.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "minimatch": "10.2.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
